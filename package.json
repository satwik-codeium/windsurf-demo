{
  "name": "windsurf-demo",
  "version": "1.0.0",
  "description": "Agar.io clone game",
  "main": "app.py",
  "scripts": {
    "test": "jest",
    "test:selenium": "jest --testPathPattern=selenium",
    "test:all": "npm run test && npm run test:selenium"
  },
  "devDependencies": {
    "@babel/core": "^7.23.2",
    "@babel/preset-env": "^7.23.2",
    "babel-jest": "^29.7.0",
    "chromedriver": "^138.0.2",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "selenium-webdriver": "^4.34.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "moduleNameMapper": {
      "\\.(css|less|scss|sass)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "testMatch": [
      "**/__tests__/**/*.test.js",
      "**/__tests__/**/*.selenium.test.js"
    ]
  }
}
